        <!-- ====== USER ENTITY ====== -->
        <mxCell id="e200" value="&lt;b&gt;User&lt;/b&gt;&#xa;──────────────────&#xa;PK: userId (Long)&#xa;username (String) [UQ]&#xa;name (String)&#xa;password (String)&#xa;region (String)&#xa;prefecture (String)&#xa;profileImageUrl (String)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="200" width="230" height="175" as="geometry" />
        </mxCell>

        <!-- ====== PROFILE ENTITY ====== -->

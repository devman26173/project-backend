          <mxGeometry x="150" y="200" width="230" height="145" as="geometry" />
        </mxCell>

        <!-- ====== POST ENTITY ====== -->
        <mxCell id="e220" value="&lt;b&gt;Post&lt;/b&gt;&#xa;──────────────────&#xa;PK: id (Long)&#xa;content (String)&#xa;──────────────────&#xa;FK: user_id → User" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="100" width="220" height="135" as="geometry" />
        </mxCell>

        <!-- ====== FOODBOARD ENTITY ====== -->
        <mxCell id="e230" value="&lt;b&gt;FoodBoard&lt;/b&gt;&#xa;──────────────────&#xa;PK: Id (Long)&#xa;title (String)&#xa;region (String)&#xa;prefecture (String)&#xa;rating (Integer)&#xa;content (TEXT)&#xa;imageUrls (String)&#xa;createdAt (LocalDateTime)&#xa;viewCount (int, default=0)&#xa;──────────────────&#xa;FK: user_id → User" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="490" width="230" height="255" as="geometry" />
        </mxCell>

        <!-- ====== COMMENT ENTITY ====== -->
        <mxCell id="e240" value="&lt;b&gt;Comment&lt;/b&gt;&#xa;──────────────────&#xa;PK: id (Long)&#xa;postId (Long) [→ FoodBoard]&#xa;parentId (Long) [null=최상위]&#xa;content (String)&#xa;author (String)&#xa;createdAt (LocalDateTime)&#xa;──────────────────&#xa;FK: user_id → User" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="390" width="230" height="210" as="geometry" />
        </mxCell>

        <!-- ====== LIKE ENTITY ====== -->
        <mxCell id="e250" value="&lt;b&gt;Like&lt;/b&gt;&#xa;──────────────────&#xa;PK: id (Long)&#xa;targetId (Long)&#xa;targetType (String)&#xa;  [POST / COMMENT / REPLY / BOARD]&#xa;userId (String)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
